APP_NAME="Sego Sambelan"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sego_sambelan
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120

FILESYSTEM_DISK=local

# database = butuh tabel cache (php artisan cache:table && migrate). Alternatif: file
CACHE_STORE=database

MIDTRANS_SERVER_KEY=SB-Mid-server-YOUR_SERVER_KEY
MIDTRANS_CLIENT_KEY=SB-Mid-client-YOUR_CLIENT_KEY
MIDTRANS_IS_PRODUCTION=false
# Verifikasi SSL ke API Midtrans (cURL). false = nonaktifkan verifikasi (hanya bila perlu, mis. Windows tanpa cacert).
MIDTRANS_VERIFY_SSL=true
# Opsional: path absolut ke cacert.pem — https://curl.se/ca/cacert.pem
# MIDTRANS_CAINFO=C:/php/extras/ssl/cacert.pem
